function TransactionModal({ isOpen, type, onClose, onSubmit }) {
  const getTodayDate = () => new Date().toISOString().split('T')[0];
  
  const [formData, setFormData] = useState({
    amount: '',
    category: '',
    date: getTodayDate(),
    description: ''
  });

  React.useEffect(() => {
    if (isOpen) {
      setFormData(prev => ({
        ...prev,
        amount: '',
        description: '',
        category: type === 'income' ? 'Gaji' : 'Belanja',
        date: getTodayDate()
      }));
    }
  }, [isOpen, type]);

  const incomeCategories = ['Gaji', 'Bonus', 'Investasi', 'Hadiah', 'Lainnya'];
  const expenseCategories = ['Belanja', 'Tagihan', 'Transportasi', 'Makanan', 'Kesehatan', 'Pendidikan', 'Hiburan', 'Lainnya'];
  const currentCategories = type === 'income' ? incomeCategories : expenseCategories;
  const isIncome = type === 'income';

  const handleSubmit = (e) => {
    e.preventDefault();
    if (!formData.amount || !formData.description) return;
    
    onSubmit({
      id: Date.now(),
      type,
      ...formData,
      amount: parseFloat(formData.amount)
    });
  };

  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 z-[100] flex items-end sm:items-center justify-center p-0 sm:p-4">
      <div className="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" onClick={onClose}></div>
      <div className="relative w-full sm:max-w-md bg-white sm:rounded-3xl rounded-t-3xl shadow-2xl overflow-hidden animate-fade-in-up sm:animate-pop-in">
        <div className={`px-6 py-5 flex justify-between items-center text-white ${isIncome ? 'bg-gradient-to-r from-emerald-400 to-emerald-500' : 'bg-gradient-to-r from-rose-400 to-rose-500'}`}>
          <h3 className="text-xl font-bold flex items-center gap-2">
            {isIncome ? <IconTrendingUp className="w-6 h-6" /> : <IconTrendingDown className="w-6 h-6" />}
            Catat {isIncome ? 'Pemasukan' : 'Pengeluaran'}
          </h3>
          <button onClick={onClose} className="p-1.5 hover:bg-white/20 rounded-full transition-colors">
            <IconX className="w-6 h-6" />
          </button>
        </div>
        
        <form onSubmit={handleSubmit} className="p-6 space-y-6">
          <div className="text-center group">
            <label className="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Nominal (Rp)</label>
            <input 
              type="number" 
              required
              min="0"
              autoFocus
              value={formData.amount}
              onChange={(e) => setFormData({...formData, amount: e.target.value})}
              className={`w-full text-center text-4xl sm:text-5xl font-extrabold rounded-2xl border-none bg-slate-50 py-4 focus:bg-white focus:ring-4 outline-none transition-all placeholder:text-slate-200 ${isIncome ? 'text-emerald-600 focus:ring-emerald-100' : 'text-rose-600 focus:ring-rose-100'}`}
              placeholder="0"
            />
          </div>

          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5 ml-1">Kategori</label>
              <select 
                value={formData.category}
                onChange={(e) => setFormData({...formData, category: e.target.value})}
                className="w-full rounded-2xl border-slate-200 bg-slate-50/50 px-4 py-3 text-sm focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-100 outline-none transition-all appearance-none font-medium text-slate-700"
              >
                {currentCategories.map(cat => <option key={cat} value={cat}>{cat}</option>)}
              </select>
            </div>
            <div>
              <label className="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5 ml-1">Tanggal</label>
              <input 
                type="date" 
                required
                value={formData.date}
                onChange={(e) => setFormData({...formData, date: e.target.value})}
                className="w-full rounded-2xl border-slate-200 bg-slate-50/50 px-4 py-3 text-sm focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-medium text-slate-700"
              />
            </div>
          </div>

          <div>
            <label className="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5 ml-1">Keterangan</label>
            <input 
              type="text" 
              required
              value={formData.description}
              onChange={(e) => setFormData({...formData, description: e.target.value})}
              className="w-full rounded-2xl border-slate-200 bg-slate-50/50 px-4 py-3 text-sm focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-medium text-slate-700"
              placeholder="Cth: Belanja mingguan"
            />
          </div>

          <button 
            type="submit"
            className={`w-full text-white font-bold py-4 rounded-2xl transition-all shadow-lg hover:-translate-y-0.5 active:scale-[0.98] text-lg mt-2 ${isIncome ? 'bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 shadow-emerald-500/30' : 'bg-gradient-to-r from-rose-500 to-pink-500 hover:from-rose-600 hover:to-pink-600 shadow-rose-500/30'}`}
          >
            Simpan Transaksi
          </button>
        </form>
      </div>
    </div>
  );
}
