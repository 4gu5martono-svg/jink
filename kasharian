  // Efek untuk Simulasi Live Update Harga Pasar setiap 5 detik
  useEffect(() => {
    const parsePrice = (priceStr) => {
      const numStr = priceStr.replace(/[^0-9]/g, '');
      const suffix = priceStr.includes('/kg') ? '/kg' : '';
      return { value: parseInt(numStr, 10), suffix };
    };

    const formatPriceStr = (val, suffix) => {
      // Format angka dengan pemisah ribuan titik
      const formattedNum = val.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      return `Rp${formattedNum}${suffix}`;
    };

    const interval = setInterval(() => {
      setTickerPrices(prevPrices => prevPrices.map(item => {
        // 40% kemungkinan sebuah barang mengalami perubahan harga tiap interval
        if (Math.random() > 0.6) {
          const { value, suffix } = parsePrice(item.price);
          // Fluktuasi harga acak antara -500 hingga +500 (dalam kelipatan 100)
          const change = Math.floor(Math.random() * 11 - 5) * 100; 
          
          if (change === 0) return { ...item, trend: 'stable' };

          // Cegah harga menjadi tidak masuk akal (minimal Rp1.000)
          const newValue = Math.max(1000, value + change); 
          const trend = change > 0 ? 'up' : 'down';

          return {
            ...item,
            price: formatPriceStr(newValue, suffix),
            trend: trend
          };
        }
        // Jika tidak ada perubahan, sesekali kembalikan status trend menjadi 'stable'
        if (Math.random() > 0.8) {
           return { ...item, trend: 'stable' };
        }
        return item;
      }));
    }, 5000); // Update setiap 5 detik

